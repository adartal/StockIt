# Database (set by M1)
# Defaults to sqlite+aiosqlite:///./stockit.db when unset; safe for local dev.
DATABASE_URL=

# LLM providers (set by M3)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Data providers (set by M2)
ALPHA_VANTAGE_API_KEY=
NEWSAPI_API_KEY=
FRED_API_KEY=

# Auth (set by M7) — AUTH_SECRET MUST be byte-identical to the value in
# apps/web/.env.local so the FastAPI can verify the Auth.js HS256 session JWT.
AUTH_SECRET=
ALLOWED_EMAILS=

# Server
# Comma-separated CORS origins for the Next.js frontend. Defaults to
# http://localhost:3000,http://127.0.0.1:3000 when unset.
WEB_CORS_ORIGINS=
# Set to "0" to disable the daily 22:00 UTC watchlist refresh in local dev.
STOCKIT_SCHEDULER_ENABLED=
